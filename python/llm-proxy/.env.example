# ── Server ───────────────────────────────────────────────────────────────────
APP_NAME="LLM Proxy"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — great for dev)
DATABASE_URL=sqlite+aiosqlite:///./llm_proxy.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/llm_proxy

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_API_KEY=replace-with-your-admin-key

# ── Key rotation strategy ─────────────────────────────────────────────────────
# round_robin | priority | random
KEY_ROTATION_STRATEGY=round_robin

# ── Rate limiting ─────────────────────────────────────────────────────────────
GLOBAL_RATE_LIMIT_RPM=600
# REDIS_URL=redis://localhost:6379/0    # uncomment for distributed rate limiting

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_METRICS=true
